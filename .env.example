# AI Tutorial Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# AI CLI Tool Configuration (Optional)
# ============================================
# The app works in simulated mode by default (no API calls).
# To enable real AI tools, install them and configure below:

# Anthropic Claude CLI
# Install: npm install -g @anthropic-ai/claude-code
# Docs: https://github.com/anthropics/claude-code
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Cursor CLI (if using Cursor AI features)
# The app spawns cursor-agent CLI commands
# Requires Cursor IDE installed
# No API key needed - uses your Cursor account

# OpenAI Codex CLI (if using Codex features)
# Install the codex CLI tool
# Docs: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# Next.js Configuration
# ============================================
# Node environment
NODE_ENV=development

# Base URL for your deployment (for screenshots/SEO)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
